          >
            🕐 Transaksi Terbaru
          </div>
          <div class="card-content" style="padding: 0">
            <div
              id="list-transaksi"
              class="list list-strong-ios list-dividers-ios"
              style="margin: 0"
            >
              <ul id="ul-transaksi"></ul>
            </div>
            <div
              id="empty-transaksi"
              style="text-align: center; padding: 20px; color: #95a5a6"
            >
              <i class="icon material-icons" style="font-size: 48px"
                >receipt_long</i
              >
              <p>Belum ada transaksi hari ini</p>
