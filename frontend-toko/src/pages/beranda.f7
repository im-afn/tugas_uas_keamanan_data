  </div>
</template>

<script>
  import { laporan } from "../js/api.js";
  import { formatRupiah } from "../js/function.js";

  export default (props, { $, $f7, $store, $on }) => {
    let timerJam;

    const loadDashboard = async () => {
      try {
        const response = await laporan.getDashboard();
        if (response.status === "sukses") {
          const d = response.data;
          $store.state.dashboard = d;

          $("#txt-penjualan").text(
            "Rp " + formatRupiah(d.hari_ini.total_penjualan),
          );
          $("#txt-transaksi").text(d.hari_ini.total_transaksi + " transaksi");
          $("#txt-laba").text("Rp " + formatRupiah(d.hari_ini.laba_kotor));
          $("#txt-piutang").text(d.piutang.total_pelanggan + " orang");
          $("#txt-stok-menipis").text(d.stok.stok_menipis + " item");
          $("#txt-total-barang").text(d.stok.total_barang + " item");

          // Transaksi terbaru
          const ul = $("#ul-transaksi");
          ul.empty();

          if (d.transaksi_terbaru.length === 0) {
            $("#empty-transaksi").show();
          } else {
            $("#empty-transaksi").hide();
            d.transaksi_terbaru.forEach((t) => {
              ul.append(`
              <li>
                <div class="item-content">
                  <div class="item-inner">
                    <div class="item-title">
                      <div style="font-weight: bold; font-size: 14px;">${t.no_transaksi}</div>
                      <div style="font-size: 11px; color: #7f8c8d;">${t.kasir}</div>
                    </div>
                    <div class="item-after">
                      <span style="font-weight: bold; color: ${t.jenis === "bon" ? "#e74c3c" : "#27ae60"};">
                        Rp ${formatRupiah(t.total)}
                      </span>
                    </div>
                  </div>
                </div>
              </li>
            `);
            });
          }
        }
      } catch (err) {
        console.error("Gagal load dashboard:", err);
      }
    };

    const updateJam = () => {
      const sekarang = new Date();
      const jam = String(sekarang.getHours()).padStart(2, "0");
      const menit = String(sekarang.getMinutes()).padStart(2, "0");
      const detik = String(sekarang.getSeconds()).padStart(2, "0");
      const hari = [
        "Minggu",
        "Senin",
        "Selasa",
        "Rabu",
        "Kamis",
        "Jumat",
        "Sabtu",
      ];
      const bulan = [
        "Januari",
        "Februari",
        "Maret",
        "April",
        "Mei",
        "Juni",
        "Juli",
        "Agustus",
        "September",
        "Oktober",
        "November",
        "Desember",
      ];

      $("#jam-digital").text(`${jam}:${menit}:${detik}`);
      $("#tanggal-digital").text(
        `${hari[sekarang.getDay()]}, ${sekarang.getDate()} ${bulan[sekarang.getMonth()]} ${sekarang.getFullYear()}`,
      );
    };

    $on("pageInit", () => {
      loadDashboard();
      updateJam();
      timerJam = setInterval(updateJam, 1000);
    });

    $on("tabShow", () => {
      loadDashboard();
    });
    $on("pageBeforeOut", () => {
      clearInterval(timerJam);
    });

    return $render;
  };
</script>
